<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Kumo.WinUI.NavigationView.RailStyle.Demo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Rail NavigationView Demo">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <NavigationView
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="NavView_SelectionChanged"
            Style="{StaticResource RailNavigationViewStyle}">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Icon="Home" Tag="Home" />
                <NavigationViewItem Content="Gallery" Icon="Pictures" Tag="Gallery" />
                <NavigationViewItem Content="Models" Icon="Library" Tag="Models" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="Settings" />
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="Settings" />
            </NavigationView.FooterMenuItems>

            <NavigationView.Content>
                <Grid Padding="40,32">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Name="PageTitle"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="Home" />
                        <TextBlock
                            MaxWidth="560"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="This WinUI demo loads CustomNavigationViewStyle.xaml from the Kumo.WinUI.NavigationView.RailStyle library and applies RailNavigationViewStyle directly." />
                    </StackPanel>
                </Grid>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Window>
